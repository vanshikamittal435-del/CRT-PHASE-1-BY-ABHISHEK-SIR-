// Problem -- 4
// Print a right angled triangle

#include <iostream>
using namespace std;

int main() {
    for(int i = 1; i <= 5; i++) {
        for(int j = 1; j <= i; j++) {
            cout << "*";
        }
        cout <<"\n";
    }
}
