// problem 1 
// Print 1 to 10 using for loop 
#include <iostream>
using namespace std; 

int main() {
    for(int i = 1; i <= 10; i++){
        cout << i << " ";
    }
}

// problem 2
// Print even numbers from 0 to 10 
#include <iostream>
using namespace std; 

int main() {
    for(int i = 1; i <= 10; i++){
        if(i % 2 ==0) {     // check for even number
        cout << i << " ";
        }
    }
}

// problem 3
//print 1 to 10 using for while loop 
#include <iostream>
using namespace std; 

int main() {
    int i = 1;
    while(i <= 10){
        cout << i << " ";
        i++;
    }
}

// problem 4
//print 1 to 10 using for while loop number 
#include <iostream>
using namespace std; 

int main() {
    int i = 1;
    while(i <= 10){
        cout << i << " ";
        i+=2;
    }
}

// problem 5
//print 1 to 10 using for while loop number 
#include <iostream>
using namespace std; 

int main() {
    int i = 1;
    do { 
        cout << i << " ";
        i++;
    } while (i <= 10);
}

