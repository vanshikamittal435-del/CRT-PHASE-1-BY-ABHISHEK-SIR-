// problem 1 
// Print 1 to 10 using for loop 
#include <iostream>
using namespace std; 

int main() {
    for(int i = 1; i <= 10; i++){
        cout << i << " ";
    }
}

// problem 2
//print 1 to 10 using for while loop 
#include <iostream>
using namespace std; 

int main() {
    int i = 1;
    while(i <= 10){
        cout << i << " ";
        i++;
    }
}
